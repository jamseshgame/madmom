#!/usr/bin/env python
"""
Jamsesh Menu -- interactive frontend for madmom beatmap tools.

"""

import os
import subprocess
import sys

# Ensure Unicode output works on Windows
if sys.platform == 'win32':
    sys.stdout.reconfigure(encoding='utf-8', errors='replace')


HEADER = r"""
  _____ ______   ________  ________  _____ ______   ________  _____ ______
 |\   _ \  _   \|\   __  \|\   ___ \|\   _ \  _   \|\   __  \|\   _ \  _   \
 \ \  \\\__\ \  \ \  \|\  \ \  \_|\ \ \  \\\__\ \  \ \  \|\  \ \  \\\__\ \  \
  \ \  \\|__| \  \ \   __  \ \  \ \\ \ \  \\|__| \  \ \  \\\  \ \  \\|__| \  \
   \ \  \    \ \  \ \  \ \  \ \  \_\\ \ \  \    \ \  \ \  \\\  \ \  \    \ \  \
    \ \__\    \ \__\ \__\ \__\ \_______\ \__\    \ \__\ \_______\ \__\    \ \__\
     \|__|     \|__|\|__|\|__|\|_______|\|__|     \|__|\|_______|\|__|     \|__|

                  J A M S E S H   F O R K   v1.1
"""

MENU = """
  ┌─────────────────────────────────┐
  │  1.  Create new beatmap         │
  │  2.  Analyse beatmap            │
  │  3.  Remix beatmap              │
  │  4.  Exit                       │
  └─────────────────────────────────┘

  ┌─ Fret Rules (Hard Enforced) ───────────────────────────┐
  │                                                        │
  │  Singles:  0  1  2  3  4          Adjacent:  0+1  1+2  │
  │  Open:     (no frets)                        2+3  3+4  │
  │                                                        │
  │  Variants: Normal · Hold · Slide    (28 total types)   │
  │  Open = tap only (no holds/slides)                     │
  │  Dual-fret holds/slides must have equal duration       │
  │  Chord slides: same pair at every position (parallel)   │
  │                                                        │
  └────────────────────────────────────────────────────────┘
"""

DIFFICULTIES = [
    ('ExpertSingle', 0.3, 0.55, 16),
    ('HardSingle', 0.4, 0.75, 8),
    ('MediumSingle', 0.5, 1.0, 8),
    ('EasySingle', 0.6, 1.0, 4),
]

AUDIO_EXTENSIONS = ('.flac', '.mp3', '.ogg', '.wav')


def clear():
    os.system('cls' if os.name == 'nt' else 'clear')


def show_header():
    clear()
    print(HEADER)


def prompt(msg, default=None):
    if default:
        val = input(f'  {msg} [{default}]: ').strip()
        return val if val else default
    while True:
        val = input(f'  {msg}: ').strip()
        if val:
            return val
        print('  Please enter a value.')


def browse_audio(folder):
    """List audio files and subfolders in a directory, let user pick."""
    while True:
        entries = []
        parent = os.path.dirname(os.path.abspath(folder))

        try:
            items = sorted(os.listdir(folder), key=str.lower)
        except OSError as e:
            print(f'  Error reading folder: {e}')
            return None

        subdirs = [i for i in items if os.path.isdir(os.path.join(folder, i))]
        audio_files = [
            i for i in items
            if os.path.isfile(os.path.join(folder, i)) and os.path.splitext(i)[1].lower() in AUDIO_EXTENSIONS
        ]

        if not subdirs and not audio_files:
            print(f'\n  No audio files or subfolders in: {folder}')
            print('  Press Enter to go back.')
            input()
            folder = parent
            continue

        print(f'\n  📂 {os.path.abspath(folder)}\n')

        idx = 1
        print('    0.  .. (parent folder)')

        for d in subdirs:
            try:
                sub_items = os.listdir(os.path.join(folder, d))
                n_audio = sum(1 for f in sub_items if os.path.splitext(f)[1].lower() in AUDIO_EXTENSIONS)
                n_dirs = sum(1 for f in sub_items if os.path.isdir(os.path.join(folder, d, f)))
            except OSError:
                n_audio = 0
                n_dirs = 0
            hint_parts = []
            if n_audio:
                hint_parts.append(f'{n_audio} audio file{"s" if n_audio != 1 else ""}')
            if n_dirs:
                hint_parts.append(f'{n_dirs} subfolder{"s" if n_dirs != 1 else ""}')
            hint = f'  ({", ".join(hint_parts)})' if hint_parts else ''
            entries.append(('dir', os.path.join(folder, d)))
            print(f'    {idx}.  [DIR] {d}{hint}')
            idx += 1

        for a in audio_files:
            fpath = os.path.join(folder, a)
            size_mb = os.path.getsize(fpath) / (1024 * 1024)
            entries.append(('file', fpath))
            print(f'    {idx}.  {a}  ({size_mb:.1f} MB)')
            idx += 1

        print()
        choice = input('  Select number (or q to cancel): ').strip()

        if choice.lower() == 'q':
            return None
        if choice == '0':
            folder = parent
            continue

        try:
            ci = int(choice) - 1
            if ci < 0 or ci >= len(entries):
                raise ValueError
        except ValueError:
            print('  Invalid choice.')
            continue

        kind, selected = entries[ci]
        if kind == 'dir':
            folder = selected
        else:
            return selected


def prompt_audio_file():
    """Ask the user for an audio file or folder path, with browsing support."""
    while True:
        path = input('\n  Path to audio file or folder: ').strip()
        # Strip surrounding quotes (drag-and-drop often adds them)
        path = path.strip('"').strip("'")
        if not path:
            print('  No path entered.')
            continue

        if os.path.isdir(path):
            result = browse_audio(path)
            if result:
                return result
            continue

        if not os.path.isfile(path):
            print(f'  Not found: {path}')
            continue
        ext = os.path.splitext(path)[1].lower()
        if ext not in AUDIO_EXTENSIONS:
            print(f'  Unsupported format: {ext}')
            print(f'  Supported: {", ".join(AUDIO_EXTENSIONS)}')
            continue
        return path


def read_audio_metadata(audio_path):
    """Extract metadata (title, artist, album, year, genre) from an audio file using ffprobe."""
    meta = {}
    try:
        result = subprocess.run(
            ['ffprobe', '-v', 'quiet', '-print_format', 'json', '-show_format', audio_path],
            capture_output=True, text=True, timeout=10,
        )
        if result.returncode == 0:
            import json
            info = json.loads(result.stdout)
            tags = info.get('format', {}).get('tags', {})
            # ffprobe tag keys can be uppercase or lowercase depending on format
            tag_lower = {k.lower(): v for k, v in tags.items()}
            meta['title'] = tag_lower.get('title', '')
            meta['artist'] = tag_lower.get('artist', '')
            meta['album'] = tag_lower.get('album', '')
            meta['year'] = tag_lower.get('date', tag_lower.get('year', ''))
            meta['genre'] = tag_lower.get('genre', '')
            meta['track'] = tag_lower.get('track', tag_lower.get('tracknumber', ''))
    except (OSError, subprocess.TimeoutExpired, ValueError):
        pass
    return meta



def run_chart_generator(audio_path, output_path, song_name, difficulty, threshold, chord_threshold, quantize,
                        cache_out=None, cache_in=None):
    """Run the CloneHeroChartGenerator for a single difficulty."""
    bin_dir = os.path.dirname(os.path.abspath(__file__))
    generator = os.path.join(bin_dir, 'CloneHeroChartGenerator')

    cmd = [
        sys.executable, generator,
        audio_path,
        '-o', output_path,
        '--name', song_name,
        '--difficulty', difficulty,
        '--threshold', str(threshold),
        '--chord-threshold', str(chord_threshold),
        '--quantize', str(quantize),
        '-v',
    ]
    if cache_out:
        cmd += ['--cache-out', cache_out]
    if cache_in:
        cmd += ['--cache-in', cache_in]
    return subprocess.run(cmd, capture_output=False)


def merge_charts(chart_paths, section_names, output_path):
    """Merge multiple single-difficulty .chart files into one."""
    import re

    sections = {}
    for path, section_name in zip(chart_paths, section_names):
        with open(path, 'r') as f:
            content = f.read()
        match = re.search(r'\[' + section_name + r'\]\n\{([^}]*)\}', content)
        if match:
            sections[section_name] = match.group(1)

    # Use the first chart for Song/SyncTrack metadata
    with open(chart_paths[0], 'r') as f:
        content = f.read()
    song_match = re.search(r'\[Song\]\n\{([^}]*)\}', content)
    sync_match = re.search(r'\[SyncTrack\]\n\{([^}]*)\}', content)

    with open(output_path, 'w') as f:
        f.write('[Song]\n{' + song_match.group(1) + '}\n')
        f.write('[SyncTrack]\n{' + sync_match.group(1) + '}\n')
        f.write('[Events]\n{\n}\n')
        for section_name in section_names:
            if section_name in sections:
                f.write(f'[{section_name}]\n{{{sections[section_name]}}}\n')


FRET_NAMES = ['0', '1', '2', '3', '4']
PAIR_NAMES = {(0, 1): '0+1', (1, 2): '1+2', (2, 3): '2+3', (3, 4): '3+4'}


def analyse_chart_section(body):
    """
    Parse a chart section body and return detailed note type counts.

    Returns a dict with:
      singles: {0: n, 1: n, ...}    holds: {0: n, 1: n, ...}
      chords: {(0,1): n, ...}       chord_holds: {(0,1): n, ...}
      slides: {0: n, 1: n, ...}     open_normal: n   open_hold: n   open_slide: n
      total_events: n
    """
    import re
    from collections import defaultdict

    # Parse all N and E lines
    note_events = defaultdict(list)   # tick -> [(fret, sustain)]
    slide_ticks = defaultdict(set)    # tick -> {fret}

    for line in body.strip().split('\n'):
        line = line.strip()
        if not line:
            continue
        # Match: tick = N fret sustain
        m = re.match(r'(\d+)\s*=\s*N\s+(\d+)\s+(\d+)', line)
        if m:
            tick, fret, sustain = int(m.group(1)), int(m.group(2)), int(m.group(3))
            note_events[tick].append((fret, sustain))
            continue
        # Match: tick = E slide fret
        m = re.match(r'(\d+)\s*=\s*E\s+slide\s+(\d+)', line)
        if m:
            tick, fret = int(m.group(1)), int(m.group(2))
            slide_ticks[tick].add(fret)

    stats = {
        'singles': defaultdict(int),       # fret -> count  (sustain == 0)
        'holds': defaultdict(int),         # fret -> count  (sustain > 0)
        'chords': defaultdict(int),        # (f1,f2) -> count (sustain == 0)
        'chord_holds': defaultdict(int),   # (f1,f2) -> count (sustain > 0)
        'slides': defaultdict(int),        # fret -> count  (single slides)
        'chord_slides': defaultdict(int),  # (f1,f2) -> count (chord slides)
        'open_normal': 0,
        'open_hold': 0,
        'open_slide': 0,
        'total_events': 0,
    }

    # Count slide events (group by tick for chord slide detection)
    for tick, frets in slide_ticks.items():
        frets_sorted = sorted(frets)
        if len(frets_sorted) == 1:
            fret = frets_sorted[0]
            if fret == 7:
                stats['open_slide'] += 1
            else:
                stats['slides'][fret] += 1
        elif len(frets_sorted) == 2 and frets_sorted[1] - frets_sorted[0] == 1:
            pair = tuple(frets_sorted)
            stats['chord_slides'][pair] += 1
        else:
            for fret in frets_sorted:
                stats['slides'][fret] += 1
        stats['total_events'] += 1

    # Count note events (group by tick for chord detection)
    for tick, notes in note_events.items():
        frets_at_tick = sorted(set(f for f, _ in notes if 0 <= f <= 4))
        max_sustain = max(s for _, s in notes)
        is_hold = max_sustain > 0

        # Check for open notes (fret 7)
        has_open = any(f == 7 for f, _ in notes)
        if has_open:
            if is_hold:
                stats['open_hold'] += 1
            else:
                stats['open_normal'] += 1
            stats['total_events'] += 1
            continue

        if len(frets_at_tick) == 1:
            fret = frets_at_tick[0]
            if is_hold:
                stats['holds'][fret] += 1
            else:
                stats['singles'][fret] += 1
            stats['total_events'] += 1
        elif len(frets_at_tick) == 2:
            pair = tuple(frets_at_tick)
            if is_hold:
                stats['chord_holds'][pair] += 1
            else:
                stats['chords'][pair] += 1
            stats['total_events'] += 1
        else:
            # 3+ frets (shouldn't happen with validation, count as event)
            stats['total_events'] += 1

    return stats


def print_difficulty_summary(label, stats):
    """Print a compact 3-column summary for one difficulty."""
    total = stats['total_events']
    if total == 0:
        print(f'  {label}: no events')
        return

    def fmt(n):
        p = n / total * 100 if total > 0 else 0
        return f'{n:5d} ({p:4.1f}%)'

    print(f'  ── {label} ({total} events) ──')
    print()
    print(f'    {"Fret":<6} {"Tap":>12}  {"Hold":>12}  {"Slide":>12}')
    print(f'    {"─" * 6} {"─" * 12}  {"─" * 12}  {"─" * 12}')

    for fret in range(5):
        tap = stats['singles'].get(fret, 0)
        hold = stats['holds'].get(fret, 0)
        slide = stats['slides'].get(fret, 0)
        print(f'    {fret:<6} {fmt(tap)}  {fmt(hold)}  {fmt(slide)}')

    print()
    print(f'    {"Chord":<6} {"Tap":>12}  {"Hold":>12}  {"Slide":>12}')
    print(f'    {"─" * 6} {"─" * 12}  {"─" * 12}  {"─" * 12}')
    for pair, pname in PAIR_NAMES.items():
        tap = stats['chords'].get(pair, 0)
        hold = stats['chord_holds'].get(pair, 0)
        slide = stats['chord_slides'].get(pair, 0)
        print(f'    {pname:<6} {fmt(tap)}  {fmt(hold)}  {fmt(slide)}')

    on = stats['open_normal']
    oh = stats['open_hold']
    os_ = stats['open_slide']
    if on or oh or os_:
        print()
        print(f'    {"Open":<6} {fmt(on)}  {fmt(oh)}  {fmt(os_)}')

    print()


def count_notes(chart_path):
    """Parse chart and return detailed stats per difficulty."""
    import re

    with open(chart_path, 'r') as f:
        content = f.read()

    results = {}
    for section in ['ExpertSingle', 'HardSingle', 'MediumSingle', 'EasySingle']:
        match = re.search(r'\[' + section + r'\]\n\{([^}]*)\}', content)
        if match:
            results[section] = analyse_chart_section(match.group(1))
    return results


def create_beatmap():
    """Full beatmap creation flow."""
    show_header()
    print('  ── Create New Beatmap ──\n')

    audio_path = prompt_audio_file()

    # Read metadata from audio file
    meta = read_audio_metadata(audio_path)

    basename = os.path.splitext(os.path.basename(audio_path))[0]
    fallback_name = basename.replace('.', ' ').replace('_', ' ').strip()
    song_name = meta.get('title') or fallback_name
    artist = meta.get('artist') or 'Unknown'
    album = meta.get('album') or 'Unknown'
    year = meta.get('year') or 'Unknown'
    genre = meta.get('genre') or 'Unknown'

    print(f'  Song:   {song_name}')
    print(f'  Artist: {artist}')
    print(f'  Album:  {album}')
    print(f'  Year:   {year}')
    print(f'  Genre:  {genre}')

    # Create output folder: "Artist - Title" next to the audio file
    safe_artist = artist.replace('/', '-').replace('\\', '-').replace(':', '-').strip()
    safe_title = song_name.replace('/', '-').replace('\\', '-').replace(':', '-').strip()
    folder_name = f'{safe_artist} - {safe_title}'
    parent_dir = os.path.dirname(os.path.abspath(audio_path))
    out_dir = os.path.join(parent_dir, folder_name)
    os.makedirs(out_dir, exist_ok=True)
    print(f'\n  Output:  {out_dir}')

    # Convert audio to song.ogg
    ogg_path = os.path.join(out_dir, 'song.ogg')
    print('\n  Converting audio to song.ogg...')
    ffmpeg_result = subprocess.run(
        ['ffmpeg', '-y', '-i', audio_path, '-vn', '-codec:a', 'libvorbis', '-q:a', '6', ogg_path],
        capture_output=True, text=True,
    )
    if ffmpeg_result.returncode != 0:
        print(f'  WARNING: ffmpeg conversion failed: {ffmpeg_result.stderr.strip()[-200:]}')
    else:
        ogg_size = os.path.getsize(ogg_path) / (1024 * 1024)
        print(f'  song.ogg created ({ogg_size:.1f} MB)')

    print('\n  ── Analysing audio ──\n')

    cache_path = os.path.join(out_dir, '_analysis_cache.npz')
    temp_charts = []
    section_names = []

    for i, (difficulty, threshold, chord_thresh, quantize) in enumerate(DIFFICULTIES):
        label = difficulty.replace('Single', '')
        temp_path = os.path.join(out_dir, f'_temp_{difficulty}.chart')
        temp_charts.append(temp_path)
        section_names.append(difficulty)

        if i == 0:
            # First difficulty: run full analysis and cache results
            result = run_chart_generator(
                audio_path, temp_path, song_name,
                difficulty, threshold, chord_thresh, quantize,
                cache_out=cache_path,
            )
            print(f'\n  ── Generating 4 difficulty levels ──\n')
            if result.returncode != 0:
                print(f'  [{label}] FAILED (exit code {result.returncode})')
            else:
                print(f'  [{label}] done.')
        else:
            # Subsequent difficulties: reuse cached analysis
            print(f'  [{label}] generating...')
            result = run_chart_generator(
                audio_path, temp_path, song_name,
                difficulty, threshold, chord_thresh, quantize,
                cache_in=cache_path,
            )
            if result.returncode != 0:
                print(f'  [{label}] FAILED (exit code {result.returncode})')
            else:
                print(f'  [{label}] done.')
        print()

    # Merge into final chart
    chart_output = os.path.join(out_dir, 'notes_fixed_slides.chart')
    print(f'  Merging charts...')
    merge_charts(temp_charts, section_names, chart_output)

    # Clean up temp files
    for p in temp_charts + [cache_path]:
        if os.path.exists(p):
            os.remove(p)

    # Get stats before writing ini (so we can include summaries)
    all_stats = count_notes(chart_output)

    # Write song.ini
    ini_path = os.path.join(out_dir, 'song.ini')
    with open(ini_path, 'w') as f:
        f.write('[song]\n')
        f.write(f'name = {song_name}\n')
        f.write(f'artist = {artist}\n')
        f.write(f'album = {album}\n')
        f.write(f'genre = {genre}\n')
        f.write(f'year = {year}\n')
        f.write('charter = Jamsesh\n')
        f.write('diff_guitar = -1\n')
        f.write('preview_start_time = 0\n')
        f.write('delay = 0\n')
        f.write('loading_phrase =\n')

        # Note type summaries per difficulty
        for section in section_names:
            if section not in all_stats:
                continue
            stats = all_stats[section]
            prefix = section.replace('Single', '').lower()
            total = stats['total_events']
            f.write(f'\n[{prefix}_stats]\n')
            f.write(f'total_events = {total}\n')
            for fret in range(5):
                f.write(f'single_{fret} = {stats["singles"].get(fret, 0)}\n')
            for fret in range(5):
                f.write(f'hold_{fret} = {stats["holds"].get(fret, 0)}\n')
            for fret in range(5):
                f.write(f'slide_{fret} = {stats["slides"].get(fret, 0)}\n')
            for pair, pname in PAIR_NAMES.items():
                f.write(f'chord_{pname} = {stats["chords"].get(pair, 0)}\n')
            for pair, pname in PAIR_NAMES.items():
                f.write(f'chord_hold_{pname} = {stats["chord_holds"].get(pair, 0)}\n')
            for pair, pname in PAIR_NAMES.items():
                f.write(f'chord_slide_{pname} = {stats["chord_slides"].get(pair, 0)}\n')
            f.write(f'open_normal = {stats["open_normal"]}\n')
            f.write(f'open_hold = {stats["open_hold"]}\n')
            f.write(f'open_slide = {stats["open_slide"]}\n')

    # Show summary
    print('\n  ── Summary ──\n')
    for section in section_names:
        if section in all_stats:
            label = section.replace('Single', '')
            print_difficulty_summary(label, all_stats[section])

    print(f'  ── Output folder ──\n')
    print(f'  {out_dir}')
    print(f'    notes_fixed_slides.chart')
    print(f'    song.ini')
    print(f'    song.ogg')

    input('\n  Press Enter to continue...')


def browse_charts(folder):
    """List .chart files and subfolders in a directory, let user pick."""
    while True:
        entries = []
        parent = os.path.dirname(os.path.abspath(folder))

        # Collect subfolders and .chart files
        try:
            items = sorted(os.listdir(folder), key=str.lower)
        except OSError as e:
            print(f'  Error reading folder: {e}')
            return None

        subdirs = [i for i in items if os.path.isdir(os.path.join(folder, i))]
        charts = [i for i in items if i.lower().endswith('.chart') and os.path.isfile(os.path.join(folder, i))]

        if not subdirs and not charts:
            print(f'\n  No .chart files or subfolders in: {folder}')
            print('  Press Enter to go back.')
            input()
            folder = parent
            continue

        print(f'\n  📂 {os.path.abspath(folder)}\n')

        idx = 1
        # Option to go up
        print(f'    0.  .. (parent folder)')

        # List subfolders first
        for d in subdirs:
            # Count .chart files inside (non-recursive quick peek)
            try:
                sub_items = os.listdir(os.path.join(folder, d))
                n_charts = sum(1 for f in sub_items if f.lower().endswith('.chart'))
                n_dirs = sum(1 for f in sub_items if os.path.isdir(os.path.join(folder, d, f)))
            except OSError:
                n_charts = 0
                n_dirs = 0
            hint_parts = []
            if n_charts:
                hint_parts.append(f'{n_charts} chart{"s" if n_charts != 1 else ""}')
            if n_dirs:
                hint_parts.append(f'{n_dirs} subfolder{"s" if n_dirs != 1 else ""}')
            hint = f'  ({", ".join(hint_parts)})' if hint_parts else ''
            entries.append(('dir', os.path.join(folder, d)))
            print(f'    {idx}.  [DIR] {d}{hint}')
            idx += 1

        # List .chart files
        for c in charts:
            fpath = os.path.join(folder, c)
            size_kb = os.path.getsize(fpath) / 1024
            entries.append(('file', fpath))
            print(f'    {idx}.  {c}  ({size_kb:.0f} KB)')
            idx += 1

        print()
        choice = input('  Select number (or q to cancel): ').strip()

        if choice.lower() == 'q':
            return None
        if choice == '0':
            folder = parent
            continue

        try:
            ci = int(choice) - 1
            if ci < 0 or ci >= len(entries):
                raise ValueError
        except ValueError:
            print('  Invalid choice.')
            continue

        kind, selected = entries[ci]
        if kind == 'dir':
            folder = selected
        else:
            return selected


def prompt_chart_file():
    """Ask the user for a .chart file or folder path, with browsing support."""
    while True:
        path = input('\n  Path to .chart file or folder: ').strip()
        path = path.strip('"').strip("'")
        if not path:
            print('  No path entered.')
            continue

        if os.path.isdir(path):
            result = browse_charts(path)
            if result:
                return result
            continue

        if not os.path.isfile(path):
            print(f'  Not found: {path}')
            continue
        if not path.lower().endswith('.chart'):
            print('  File must be a .chart file.')
            continue
        return path


def format_duration(seconds):
    """Format seconds as M:SS."""
    m = int(seconds) // 60
    s = int(seconds) % 60
    return f'{m}:{s:02d}'


def analyse_beatmap():
    """Full chart analysis with detailed report."""
    import re
    from collections import Counter

    show_header()
    print('  ── Analyse Beatmap ──\n')

    chart_path = prompt_chart_file()

    with open(chart_path, 'r') as f:
        content = f.read()

    # ── Parse [Song] metadata ──
    song_match = re.search(r'\[Song\]\n\{([^}]*)\}', content)
    song_meta = {}
    if song_match:
        for line in song_match.group(1).strip().split('\n'):
            line = line.strip()
            if '=' in line:
                key, _, val = line.partition('=')
                song_meta[key.strip()] = val.strip().strip('"')

    song_name = song_meta.get('Name', 'Unknown')
    resolution = int(song_meta.get('Resolution', 192))
    offset = float(song_meta.get('Offset', 0))

    # ── Parse [SyncTrack] ──
    sync_match = re.search(r'\[SyncTrack\]\n\{([^}]*)\}', content)
    bpm_events = []
    ts_events = []
    if sync_match:
        for line in sync_match.group(1).strip().split('\n'):
            line = line.strip()
            m = re.match(r'(\d+) = B (\d+)', line)
            if m:
                bpm_events.append((int(m.group(1)), int(m.group(2)) / 1000.0))
            m = re.match(r'(\d+) = TS (\d+)', line)
            if m:
                ts_events.append((int(m.group(1)), int(m.group(2))))

    primary_bpm = bpm_events[0][1] if bpm_events else 0
    time_sig = f'{ts_events[0][1]}/4' if ts_events else '4/4'

    # ── Parse song.ini if present ──
    ini_path = os.path.join(os.path.dirname(os.path.abspath(chart_path)), 'song.ini')
    ini_meta = {}
    if os.path.isfile(ini_path):
        with open(ini_path, 'r') as f:
            for line in f:
                line = line.strip()
                if '=' in line and not line.startswith('['):
                    key, _, val = line.partition('=')
                    ini_meta[key.strip()] = val.strip()

    artist = ini_meta.get('artist', '')
    album = ini_meta.get('album', '')
    genre = ini_meta.get('genre', '')
    year = ini_meta.get('year', '')
    charter = ini_meta.get('charter', '')

    # ── Find which difficulty sections exist ──
    all_sections = ['ExpertSingle', 'HardSingle', 'MediumSingle', 'EasySingle']
    present_sections = []
    for s in all_sections:
        if re.search(r'\[' + s + r'\]', content):
            present_sections.append(s)

    # ── Compute song duration from last tick ──
    last_tick = 0
    for s in present_sections:
        match = re.search(r'\[' + s + r'\]\n\{([^}]*)\}', content)
        if match:
            for m in re.finditer(r'(\d+) =', match.group(1)):
                t = int(m.group(1))
                if t > last_tick:
                    last_tick = t
    if primary_bpm > 0:
        song_duration_sec = (last_tick / resolution) * (60.0 / primary_bpm)
    else:
        song_duration_sec = 0

    # ══════════════════════════════════════
    #  PRINT REPORT
    # ══════════════════════════════════════

    show_header()
    print('  ══════════════════════════════════════════════════════════════')
    print('                     B E A T M A P   R E P O R T')
    print('  ══════════════════════════════════════════════════════════════')

    # ── Song Info ──
    print('\n  ── Song Info ──\n')
    print(f'  Song:        {song_name}')
    if artist:
        print(f'  Artist:      {artist}')
    if album:
        print(f'  Album:       {album}')
    if genre:
        print(f'  Genre:       {genre}')
    if year:
        print(f'  Year:        {year}')
    if charter:
        print(f'  Charter:     {charter}')

    # ── Chart Properties ──
    print('\n  ── Chart Properties ──\n')
    print(f'  File:        {os.path.basename(chart_path)}')
    print(f'  Resolution:  {resolution} ticks/quarter note')
    print(f'  Offset:      {offset} ms')
    print(f'  BPM:         {primary_bpm:.2f}')
    if len(bpm_events) > 1:
        bpms = [b for _, b in bpm_events]
        print(f'  BPM changes: {len(bpm_events)} (range {min(bpms):.2f} - {max(bpms):.2f})')
    print(f'  Time sig:    {time_sig}')
    print(f'  Duration:    {format_duration(song_duration_sec)} (est. from last note)')
    print(f'  Difficulties: {len(present_sections)} ({", ".join(s.replace("Single", "") for s in present_sections)})')

    # ── Per-difficulty analysis ──
    for section in present_sections:
        match = re.search(r'\[' + section + r'\]\n\{([^}]*)\}', content)
        if not match:
            continue
        body = match.group(1)
        label = section.replace('Single', '')

        # Parse notes and events
        tick_notes = {}
        slide_start_count = 0
        slide_frets_used = Counter()

        for line in body.strip().split('\n'):
            line = line.strip()
            if not line:
                continue
            m = re.match(r'(\d+) = N (\d+) (\d+)', line)
            if m:
                tick, fret, sustain = int(m.group(1)), int(m.group(2)), int(m.group(3))
                if 0 <= fret <= 4:
                    tick_notes.setdefault(tick, []).append((fret, sustain))
                continue
            m2 = re.match(r'(\d+) = E slide (\d+)', line)
            if m2:
                slide_start_count += 1
                slide_frets_used[int(m2.group(2))] += 1

        if not tick_notes:
            print(f'\n  ── {label} ──  (empty)')
            continue

        # Classify each tick
        single_frets = Counter()
        chord_pairs = Counter()
        holds = 0
        taps = 0
        sustain_ticks_list = []
        total_events = 0
        all_frets_flat = Counter()

        ticks_sorted = sorted(tick_notes.keys())
        for tick in ticks_sorted:
            notes = tick_notes[tick]
            frets = sorted(set(n[0] for n in notes))
            max_sustain = max(n[1] for n in notes)
            total_events += 1

            for f in frets:
                all_frets_flat[f] += 1

            if max_sustain > 0:
                holds += 1
                sustain_ticks_list.append(max_sustain)
            else:
                taps += 1

            if len(frets) == 1:
                single_frets[frets[0]] += 1
            elif len(frets) == 2:
                chord_pairs[(frets[0], frets[1])] += 1

        single_total = sum(single_frets.values())
        chord_total = sum(chord_pairs.values())

        # Timing stats
        if len(ticks_sorted) >= 2:
            gaps = [ticks_sorted[i + 1] - ticks_sorted[i] for i in range(len(ticks_sorted) - 1)]
            avg_gap_ticks = sum(gaps) / len(gaps)
            min_gap_ticks = min(gaps)
            max_gap_ticks = max(gaps)
            if primary_bpm > 0:
                avg_gap_sec = (avg_gap_ticks / resolution) * (60.0 / primary_bpm)
                min_gap_sec = (min_gap_ticks / resolution) * (60.0 / primary_bpm)
                max_gap_sec = (max_gap_ticks / resolution) * (60.0 / primary_bpm)
            else:
                avg_gap_sec = min_gap_sec = max_gap_sec = 0
            nps = 1.0 / avg_gap_sec if avg_gap_sec > 0 else 0
        else:
            avg_gap_sec = min_gap_sec = max_gap_sec = nps = 0

        # Sustain stats
        if sustain_ticks_list:
            avg_sustain = sum(sustain_ticks_list) / len(sustain_ticks_list)
            min_sustain = min(sustain_ticks_list)
            max_sustain = max(sustain_ticks_list)
            if primary_bpm > 0:
                avg_sustain_sec = (avg_sustain / resolution) * (60.0 / primary_bpm)
                min_sustain_sec = (min_sustain / resolution) * (60.0 / primary_bpm)
                max_sustain_sec = (max_sustain / resolution) * (60.0 / primary_bpm)
            else:
                avg_sustain_sec = min_sustain_sec = max_sustain_sec = 0
        else:
            avg_sustain_sec = min_sustain_sec = max_sustain_sec = 0

        # Density: notes per second over 5-second windows
        if primary_bpm > 0 and song_duration_sec > 0:
            window_sec = 5.0
            window_ticks = int(window_sec * primary_bpm / 60.0 * resolution)
            densities = []
            for start_tick in range(0, last_tick, window_ticks):
                end_tick = start_tick + window_ticks
                count_in_window = sum(1 for t in ticks_sorted if start_tick <= t < end_tick)
                densities.append(count_in_window / window_sec)
            peak_density = max(densities) if densities else 0
            peak_window_idx = densities.index(peak_density) if densities else 0
            peak_time_sec = peak_window_idx * window_sec
        else:
            peak_density = 0
            peak_time_sec = 0

        # First/last note times
        first_tick = ticks_sorted[0]
        last_note_tick = ticks_sorted[-1]
        if primary_bpm > 0:
            first_note_sec = (first_tick / resolution) * (60.0 / primary_bpm)
            last_note_sec = (last_note_tick / resolution) * (60.0 / primary_bpm)
            active_duration = last_note_sec - first_note_sec
        else:
            first_note_sec = last_note_sec = active_duration = 0

        # ── Print section ──
        print(f'\n  {"═" * 60}')
        print(f'  ── {label} ──')
        print(f'  {"═" * 60}')

        print(f'\n  Overview:')
        print(f'    Total events:     {total_events}')
        print(f'    First note:       {format_duration(first_note_sec)}')
        print(f'    Last note:        {format_duration(last_note_sec)}')
        print(f'    Active duration:  {format_duration(active_duration)}')
        print(f'    Avg notes/sec:    {nps:.1f}')
        print(f'    Peak notes/sec:   {peak_density:.1f} (at {format_duration(peak_time_sec)})')

        print(f'\n  Note types:')
        print(f'    Singles:          {single_total:5d}  ({single_total / total_events * 100:.1f}%)')
        print(f'    Chords:           {chord_total:5d}  ({chord_total / total_events * 100:.1f}%)')
        print(f'    Holds:            {holds:5d}  ({holds / total_events * 100:.1f}%)')
        print(f'    Taps:             {taps:5d}  ({taps / total_events * 100:.1f}%)')
        print(f'    Slide events:     {slide_start_count:5d}')

        if holds > 0:
            print(f'\n  Sustain durations:')
            print(f'    Avg:  {avg_sustain_sec:.3f}s  ({avg_sustain:.0f} ticks)')
            print(f'    Min:  {min_sustain_sec:.3f}s  ({min_sustain:.0f} ticks)')
            print(f'    Max:  {max_sustain_sec:.3f}s  ({max_sustain:.0f} ticks)')

        print(f'\n  Note spacing:')
        print(f'    Avg gap:  {avg_gap_sec:.3f}s  ({avg_gap_ticks:.0f} ticks)')
        print(f'    Min gap:  {min_gap_sec:.3f}s  ({min_gap_ticks:.0f} ticks)')
        print(f'    Max gap:  {max_gap_sec:.3f}s  ({max_gap_ticks:.0f} ticks)')

        print(f'\n  Single fret distribution:')
        bar_width = 30
        max_single = max(single_frets.values()) if single_frets else 1
        fret_names = ['0     ', '1     ', '2     ', '3     ', '4     ']
        for fret in range(5):
            c = single_frets.get(fret, 0)
            pct = c / total_events * 100 if total_events else 0
            bar_len = int(c / max_single * bar_width) if max_single > 0 else 0
            bar = '█' * bar_len
            print(f'    {fret} {fret_names[fret]}  {c:5d}  ({pct:5.1f}%)  {bar}')

        if chord_total > 0:
            print(f'\n  Chord distribution:')
            max_chord = max(chord_pairs.values()) if chord_pairs else 1
            pair_names = ['0+1   ', '1+2   ', '2+3   ', '3+4   ']
            for idx, pair in enumerate([(0, 1), (1, 2), (2, 3), (3, 4)]):
                c = chord_pairs.get(pair, 0)
                pct = c / total_events * 100 if total_events else 0
                bar_len = int(c / max_chord * bar_width) if max_chord > 0 else 0
                bar = '█' * bar_len
                print(f'    {pair[0]}+{pair[1]} {pair_names[idx]}  {c:5d}  ({pct:5.1f}%)  {bar}')

        # Overall fret usage (counting each fret in a chord separately)
        total_fret_hits = sum(all_frets_flat.values())
        print(f'\n  Overall fret usage (inc. chords):')
        max_fret_hit = max(all_frets_flat.values()) if all_frets_flat else 1
        for fret in range(5):
            c = all_frets_flat.get(fret, 0)
            pct = c / total_fret_hits * 100 if total_fret_hits else 0
            bar_len = int(c / max_fret_hit * bar_width) if max_fret_hit > 0 else 0
            bar = '█' * bar_len
            print(f'    {fret} {fret_names[fret]}  {c:5d}  ({pct:5.1f}%)  {bar}')

        if slide_start_count > 0:
            print(f'\n  Slide frets used:')
            for fret in range(5):
                c = slide_frets_used.get(fret, 0)
                if c > 0:
                    print(f'    {fret} {fret_names[fret]}  {c}')

    print(f'\n  {"═" * 60}')
    print('  End of report.')
    print(f'  {"═" * 60}')

    input('\n  Press Enter to continue...')


def remix_beatmap():
    """Placeholder for future remix functionality."""
    show_header()
    print('  ── Remix Beatmap ──\n')
    print('  Coming soon. This will allow you to:')
    print('    - Load an existing .chart file')
    print('    - Adjust difficulty parameters')
    print('    - Regenerate specific difficulty levels')
    print('    - Shift/scale fret assignments')
    print('    - Edit slide detection sensitivity')
    input('\n  Press Enter to continue...')


def main():
    while True:
        show_header()
        print(MENU)
        choice = input('  Select option: ').strip()

        if choice == '1':
            create_beatmap()
        elif choice == '2':
            analyse_beatmap()
        elif choice == '3':
            remix_beatmap()
        elif choice == '4':
            show_header()
            print('  See you next jam.\n')
            break
        else:
            print('\n  Invalid option. Press Enter to try again.')
            input()


if __name__ == '__main__':
    main()
