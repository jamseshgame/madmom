[Unit]
Description=Jamsesh Beatmap API
After=network.target

[Service]
Type=exec
User=www-data
Group=www-data
WorkingDirectory=/opt/madmom/web/backend
EnvironmentFile=/opt/madmom/web/.env
ExecStart=/opt/madmom/web/backend/venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
