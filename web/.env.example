# Server
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=https://beatmap.jamsesh.co,http://localhost:5173

# File handling
# IMPORTANT: must be a persistent path. Do NOT use /tmp/* — most distros
# (Ubuntu via systemd-tmpfiles, etc.) wipe /tmp on every reboot, which will
# silently destroy every uploaded track. For prod use a /var/lib/<app>/ path;
# for local dev a project-relative path is fine.
UPLOAD_DIR=./beatmap-uploads
MAX_UPLOAD_MB=200
JOB_TTL_MINUTES=60

# Stem separation — checkpoint cache for the Roformer / MDX-Net / VR engines
# (audio-separator). Models are a few hundred MB each and download on first
# use. Blank = <UPLOAD_DIR>/audio-separator-models. Same rule as UPLOAD_DIR:
# never point this at /tmp, or every reboot re-downloads the lot.
AUDIO_SEPARATOR_MODEL_DIR=

# GitHub publishing
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=jamseshgame
GITHUB_REPO=JamseshSongContent
GITHUB_BRANCH=main
GITHUB_INBOX_PREFIX=SongInbox

# ElevenLabs (Phase 1+ TTS)
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DigitalOcean
DO_API_TOKEN=dop_v1_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# madmom project root (parent of web/)
MADMOM_ROOT=/opt/madmom

# Default beatmap model when creating a new chart. "madmom" = legacy, "v2" = pipeline.
BEATMAP_MODEL_DEFAULT=madmom

# Path to a Netscape-format cookies.txt exported from a signed-in YouTube
# session. Required on cloud IPs that YouTube has flagged for bot detection
# (most DigitalOcean / AWS / GCP droplets). Leave empty on home networks.
# Export with the "Get cookies.txt LOCALLY" browser extension while signed
# into youtube.com, then scp the file to the server.
YOUTUBE_COOKIES_FILE=

# 3D-preview assets for the beatmap editor's runway view — gem meshes
# (.fbx/.glb/.gltf/.obj) and highway textures (images). These default to a
# local JamseshQuest Unity checkout (a Windows path). On a server with no
# Unity checkout, copy the asset files over and point these at them; leave
# empty to fall back to 2D circles / a plain dark highway.
JAMSESHQUEST_GEMS_DIR=
JAMSESHQUEST_HIGHWAYS_DIR=

# Claude integration for the "Propose new presets from feedback" button.
# Get a key from https://console.anthropic.com. Omitted = the endpoint
# returns 503.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=8192
