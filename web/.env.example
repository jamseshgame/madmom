# Server
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=https://beatmap.jamsesh.co,http://localhost:5173

# File handling
UPLOAD_DIR=/tmp/beatmap-uploads
MAX_UPLOAD_MB=200
JOB_TTL_MINUTES=60

# GitHub publishing
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=jamseshgame
GITHUB_REPO=JamseshSongContent
GITHUB_BRANCH=main
GITHUB_INBOX_PREFIX=SongInbox

# ElevenLabs (Phase 1+ TTS)
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DigitalOcean
DO_API_TOKEN=dop_v1_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# madmom project root (parent of web/)
MADMOM_ROOT=/opt/madmom
